#!/bin/sh
# Refuse to publish tailscale hostnames or live capability keys.
#
# The funnel in front of `substrate serve` is protected by an unguessable
# hostname plus a key — obscurity that only holds if the repo never
# broadcasts either. This scans every commit about to leave the machine
# (not just HEAD: an old commit publishes its history too) and blocks the
# push with the offending lines. Redact, recommit, push again.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Knowingly-safe line?    add the marker: redaction-ok

# real ts.net hostnames; tailnet names; live keys/nonces (long values only —
# docs placeholders like "key=…" and short examples don't match)
PATTERNS='taile[0-9a-f][0-9a-f]*|[a-z0-9][a-z0-9-]*\.ts\.net|(key|nonce)=[0-9a-zA-Z]\{16,\}'
ZERO=0000000000000000000000000000000000000000

fail=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ "$local_sha" = "$ZERO" ] && continue # deleting a remote ref
    if [ "$remote_sha" = "$ZERO" ]; then
        range="$local_sha" # new branch: scan its whole history
    else
        range="$remote_sha..$local_sha"
    fi
    for rev in $(git rev-list "$range"); do
        hits=$(git grep -nIE "$PATTERNS" "$rev" 2>/dev/null | grep -v 'redaction-ok')
        if [ -n "$hits" ]; then
            echo "pre-push: possible funnel hostname or live key in $rev:" >&2
            echo "$hits" >&2
            fail=1
        fi
    done
done

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "push blocked — the leak lives in the commit(s) named above, so a" >&2
    echo "follow-up redaction commit is NOT enough: amend or rebase that" >&2
    echo "commit away (e.g. git rebase -i), then push. See AGENTS.md" >&2
    echo "'Security and publication'. False positive? append a 'redaction-ok'" >&2
    echo "comment on that line." >&2
    exit 1
fi
exit 0
