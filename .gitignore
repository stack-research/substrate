# --- Substrate ------------------------------------------------------------------

# Space data (threads + registry) lives in .substrate/ at a project root.
# Ignored by default: raw threads are lab chatter. To keep the lineage in
# git, remove this line — or export clean transcripts instead:
#   substrate read <thread> > docs/threads/<thread>.md
.substrate/

# Atomic-write temps if a process dies mid-rename (readers skip these anyway).
.tmp-*
